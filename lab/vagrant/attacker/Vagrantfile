# -*- mode: ruby -*-
# vi: set ft=ruby :

# Attacker Linux Vagrantfile
# Ubuntu 22.04 ARM64 with offensive tools

Vagrant.configure("2") do |config|
  # Use Ubuntu 22.04 ARM64 box (community-maintained)
  config.vm.box = "perk/ubuntu-2204-arm64"
  
  config.vm.hostname = "attacker-linux"
  config.vm.define "attacker"
  
  # Network - same subnet as caldera
  config.vm.network "private_network", ip: "192.168.56.20"
  
  # Provider settings
  # Provider settings - libvirt for ARM64
  config.vm.provider "libvirt" do |libvirt|
    libvirt.memory = "2048"
    libvirt.cpus = 2
    libvirt.machine_arch = "aarch64"
    libvirt.machine_type = "virt"
    libvirt.cpu_mode = "custom"
    libvirt.cpu_model = "cortex-a72"
    libvirt.nic_model_type = "virtio"
    libvirt.driver = "qemu"
    libvirt.uri = "qemu:///session"
  end

  config.vm.provider "qemu" do |qemu|
    qemu.memory = "2048"
    qemu.cpus = 2
    qemu.arch = "aarch64"
    qemu.machine = "virt"
    qemu.cpu = "cortex-a72"
    qemu.ssh_port = 50023
  end
  
  config.vm.provider "virtualbox" do |vb|
    vb.memory = "2048"
    vb.cpus = 2
    vb.name = "sticks-attacker-linux"
  end
  
  # Provisioning
  config.vm.provision "file", source: "../shared/apt_guard.sh", destination: "/tmp/apt_guard.sh"
  config.vm.provision "shell", path: "../shared/base.sh"
  config.vm.provision "shell", path: "../shared/attacker.sh"
end
