# -*- mode: ruby -*-
# vi: set ft=ruby :

# Caldera Server Vagrantfile
# Ubuntu 22.04 ARM64 with Caldera 5.3.0

Vagrant.configure("2") do |config|
  # Use Ubuntu 22.04 ARM64 box (community-maintained)
  config.vm.box = "perk/ubuntu-2204-arm64"
  
  # VM name and provider settings
  config.vm.hostname = "caldera-server"
  config.vm.define "caldera"
  
  # Network configuration
  config.vm.network "private_network", ip: "192.168.56.10"
  config.vm.network "forwarded_port", guest: 8888, host: 8888, auto_correct: true  # Caldera web UI
  config.vm.network "forwarded_port", guest: 7010, host: 7010, auto_correct: true  # Agent beacon
  
  # Provider settings - libvirt for ARM64
  config.vm.provider "libvirt" do |libvirt|
    libvirt.memory = "2048"
    libvirt.cpus = 2
    libvirt.machine_arch = "aarch64"
    libvirt.machine_type = "virt"
    libvirt.cpu_mode = "custom"
    libvirt.cpu_model = "cortex-a72"
    libvirt.nic_model_type = "virtio"
    libvirt.driver = "qemu"
    libvirt.uri = "qemu:///session"
  end

  config.vm.provider "qemu" do |qemu|
    qemu.memory = "2048"
    qemu.cpus = 2
    qemu.arch = "aarch64"
    qemu.machine = "virt"
    qemu.cpu = "cortex-a72"
    qemu.ssh_port = 50022
  end
  
  # VirtualBox fallback (x86_64)
  config.vm.provider "virtualbox" do |vb|
    vb.memory = "4096"
    vb.cpus = 2
    vb.name = "sticks-caldera-server"
  end
  
  # Provisioning
  config.vm.provision "file", source: "../shared/apt_guard.sh", destination: "/tmp/apt_guard.sh"
  config.vm.provision "file", source: "../shared/caldera-runtime-requirements.txt", destination: "/tmp/caldera-runtime-requirements.txt"
  config.vm.provision "shell", path: "../shared/base.sh"
  config.vm.provision "shell", path: "../shared/caldera.sh"
  config.vm.provision "shell", inline: <<-SHELL
    echo "Caldera server provisioned at 192.168.56.10"
    echo "Access: http://192.168.56.10:8888"
    echo "Default credentials: admin/admin"
  SHELL
end
