# -*- mode: ruby -*-
# vi: set ft=ruby :

# Target Linux 1 Vagrantfile
# Ubuntu 22.04 ARM64 with deliberate weaknesses

Vagrant.configure("2") do |config|
  # Use Ubuntu 22.04 ARM64 box (community-maintained)
  config.vm.box = "perk/ubuntu-2204-arm64"
  
  config.vm.hostname = "target-linux-1"
  config.vm.define "target1"
  
  # Network
  config.vm.network "private_network", ip: "192.168.56.30"
  
  # Provider settings
  # Provider settings - libvirt for ARM64
  config.vm.provider "libvirt" do |libvirt|
    libvirt.memory = "1024"
    libvirt.cpus = 1
    libvirt.machine_arch = "aarch64"
    libvirt.machine_type = "virt"
    libvirt.cpu_mode = "custom"
    libvirt.cpu_model = "cortex-a72"
    libvirt.nic_model_type = "virtio"
    libvirt.driver = "qemu"
    libvirt.uri = "qemu:///session"
  end

  config.vm.provider "qemu" do |qemu|
    qemu.memory = "1024"
    qemu.cpus = 1
    qemu.arch = "aarch64"
    qemu.machine = "virt"
    qemu.cpu = "cortex-a72"
    qemu.ssh_port = 50024
  end
  
  config.vm.provider "virtualbox" do |vb|
    vb.memory = "1024"
    vb.cpus = 1
    vb.name = "sticks-target-linux-1"
  end
  
  # Provisioning
  config.vm.provision "file", source: "../shared/apt_guard.sh", destination: "/tmp/apt_guard.sh"
  config.vm.provision "shell", path: "../shared/base.sh"
  config.vm.provision "shell", path: "../shared/target.sh"
end
