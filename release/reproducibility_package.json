{
  "title": "STICKS Reproducibility Package",
  "version": "1.1",
  "scope": "Canonical reviewer-facing smoke path",
  "updated_on": "2026-03-19",
  "requirements": {
    "python": ">=3.10"
  },
  "optional_requirements": {
    "vagrant": "optional for lab-backed workflows",
    "qemu": "optional for qemu-backed lab workflows"
  },
  "setup_instructions": [
    "Run: ./artifact/setup.sh",
    "Run: ./artifact/run.sh",
    "Run: ./artifact/validate.sh"
  ],
  "notes": [
    "The canonical smoke path is host-only and does not require VMs.",
    "Optional lab workflows live under scripts/up_lab.sh and scripts/destroy_lab.sh.",
    "Published-corpus claims should be grounded in results/CORPUS_STATE.md."
  ],
  "expected_outputs": {
    "evidence": "release/evidence/<campaign>_<timestamp>/summary.json",
    "manifest": "release/evidence/<campaign>_<timestamp>/manifest.json",
    "tables": [
      "results/tables/corpus_table.tex",
      "results/tables/fidelity_table.tex",
      "results/tables/execution_table.tex"
    ]
  }
}
